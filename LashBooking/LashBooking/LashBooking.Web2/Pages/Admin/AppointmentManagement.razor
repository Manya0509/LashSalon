@using LashBooking.Domain.Entities
@using LashBooking.Domain.Interfaces
@inject IRepository<Appointment> AppointmentRepo
@inject IRepository<Client> ClientRepo
@inject IRepository<Service> ServiceRepo
@inject IJSRuntime JSRuntime

<div class="management-section">
    <div class="section-header">
        <h2><i class="bi bi-calendar-check"></i> Управление записями</h2>

        <div class="header-actions">
            <!-- Фильтры по дате -->
            <button class="filter-btn @GetFilterButtonClass("today")"
                    @onclick="FilterToday">
                Сегодня
            </button>
            <button class="filter-btn @GetFilterButtonClass("tomorrow")"
                    @onclick="FilterTomorrow">
                Завтра
            </button>
            <button class="filter-btn @GetFilterButtonClass("week")"
                    @onclick="FilterWeek">
                Неделя
            </button>
            <button class="filter-btn @GetFilterButtonClass("all")"
                    @onclick="FilterAll">
                Все
            </button>

            <!-- Кнопка обновления -->
            <button class="refresh-btn" @onclick="LoadAppointments" title="Обновить">
                <i class="bi bi-arrow-repeat"></i>
            </button>
        </div>
    </div>

    <!-- Статистика по записям -->
    <div class="appointments-stats">
        <div class="stat-item">
            <span class="stat-label">Всего:</span>
            <span class="stat-value">@allAppointments.Count</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Сегодня:</span>
            <span class="stat-value today">@todayCount</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Запланировано:</span>
            <span class="stat-value scheduled">@scheduledCount</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Подтверждено:</span>
            <span class="stat-value confirmed">@confirmedCount</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Выполнено:</span>
            <span class="stat-value completed">@completedCount</span>
        </div>
        <div class="stat-item">
            <span class="stat-label">Отменено:</span>
            <span class="stat-value cancelled">@cancelledCount</span>
        </div>
    </div>

    <!-- Поиск -->
    <div class="search-section">
        <input type="text" class="search-input"
               placeholder="🔍 Поиск по имени, телефону или услуге..."
               @bind="searchTerm"
               @bind:event="oninput" />
    </div>

    @if (isLoading)
    {
        <div class="loading-spinner">
            <div class="spinner"></div>
            <p>Загрузка записей...</p>
        </div>
    }
    else if (!filteredAppointments.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📅</div>
            <h4>Записи не найдены</h4>
            <p>По вашему запросу ничего не найдено</p>
        </div>
    }
    else
    {
        <!-- Таблица записей -->
        <div class="table-responsive">
            <table class="appointments-table">
                <thead>
                    <tr>
                        <th>Дата и время</th>
                        <th>Клиент</th>
                        <th>Телефон</th>
                        <th>Услуга</th>
                        <th>Длительность</th>
                        <th>Цена</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appointment in filteredAppointments.OrderBy(a => a.DateStart))
                    {
                        var client = GetClient(appointment.ClientId);
                        var service = GetService(appointment.ServiceId);

                        <tr class="appointment-row @GetStatusClass(appointment.Status)">
                            <td class="time-cell">
                                <strong>@appointment.DateStart.ToString("HH:mm")</strong>
                                <small>@appointment.DateStart.ToString("dd.MM.yyyy")</small>
                            </td>
                            <td>@(client?.Name ?? "—")</td>
                            <td>@(client?.Phone ?? "—")</td>
                            <td>@(service?.Name ?? "—")</td>
                            <td>@(service?.DurationMinutes ?? 0) мин</td>
                            <td class="price-cell">@((service?.Price ?? 0).ToString("C"))</td>
                            <td>
                                <select class="status-select @GetStatusClass(appointment.Status)"
                                        @onchange="(e) => UpdateStatus(appointment.Id, e.Value)">
                                    <option value="1" selected="@(appointment.Status == AppointmentStatus.Scheduled)">Запланирована</option>
                                    <option value="2" selected="@(appointment.Status == AppointmentStatus.Confirmed)">Подтверждена</option>
                                    <option value="3" selected="@(appointment.Status == AppointmentStatus.Completed)">Выполнена</option>
                                    <option value="4" selected="@(appointment.Status == AppointmentStatus.Cancelled)">Отменена</option>
                                    <option value="5" selected="@(appointment.Status == AppointmentStatus.NoShow)">Не явился</option>
                                </select>
                            </td>
                            <td class="actions-cell">
                                <button class="btn-icon edit" @onclick="() => EditAppointment(appointment.Id)" title="Редактировать">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn-icon delete" @onclick="() => DeleteAppointment(appointment.Id)" title="Удалить">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Модальное окно редактирования -->
@if (showEditModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3><i class="bi bi-pencil-square"></i> Редактирование записи</h3>
                <button class="modal-close" @onclick="CloseModal">✕</button>
            </div>
            <div class="modal-body">
                @if (editingAppointment != null)
                {
                    var client = GetClient(editingAppointment.ClientId);
                    var service = GetService(editingAppointment.ServiceId);

                    <div class="info-block">
                        <p><strong>Клиент:</strong> @client?.Name</p>
                        <p><strong>Телефон:</strong> @client?.Phone</p>
                        <p><strong>Услуга:</strong> @service?.Name</p>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Дата и время</label>
                        <input type="datetime-local" class="form-control"
                               @bind="editingDate"
                               @bind:format="yyyy-MM-ddTHH:mm" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Статус</label>
                        <select class="form-control" @bind="editingStatus">
                            <option value="1">Запланирована</option>
                            <option value="2">Подтверждена</option>
                            <option value="3">Выполнена</option>
                            <option value="4">Отменена</option>
                            <option value="5">Не явился</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Заметки</label>
                        <textarea class="form-control" @bind="editingNotes" rows="3"
                                  placeholder="Дополнительная информация..."></textarea>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Отмена</button>
                <button class="btn-primary" @onclick="SaveChanges">Сохранить</button>
            </div>
        </div>
    </div>
}

<!-- Модальное окно подтверждения удаления -->
@if (showDeleteModal)
{
    <div class="modal-overlay" @onclick="CloseDeleteModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3><i class="bi bi-exclamation-triangle"></i> Подтверждение</h3>
                <button class="modal-close" @onclick="CloseDeleteModal">✕</button>
            </div>
            <div class="modal-body">
                <p>Вы уверены, что хотите удалить эту запись?</p>
                <p class="text-muted">Это действие нельзя отменить.</p>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseDeleteModal">Нет</button>
                <button class="btn-danger" @onclick="ConfirmDelete">Да, удалить</button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;
    private List<Appointment> allAppointments = new();
    private List<Appointment> filteredAppointments = new();
    private Dictionary<int, Client> clientsCache = new();
    private Dictionary<int, Service> servicesCache = new();

    private string selectedDateFilter = "today";
    private string searchTerm = "";

    // Для редактирования
    private bool showEditModal = false;
    private Appointment? editingAppointment;
    private DateTime editingDate;
    private int editingStatus;
    private string editingNotes = "";

    // Для удаления
    private bool showDeleteModal = false;
    private int? appointmentToDelete;

    // Статистика
    private int todayCount => allAppointments.Count(a => a.DateStart.Date == DateTime.Today);
    private int scheduledCount => allAppointments.Count(a => a.Status == AppointmentStatus.Scheduled);
    private int confirmedCount => allAppointments.Count(a => a.Status == AppointmentStatus.Confirmed);
    private int completedCount => allAppointments.Count(a => a.Status == AppointmentStatus.Completed);
    private int cancelledCount => allAppointments.Count(a => a.Status == AppointmentStatus.Cancelled);

    protected override async Task OnInitializedAsync()
    {
        await LoadServices();
        await LoadAppointments();
    }

    private async Task LoadServices()
    {
        try
        {
            var services = await ServiceRepo.GetAllAsync();
            servicesCache = services.ToDictionary(s => s.Id, s => s);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки услуг: {ex.Message}");
        }
    }

    private async Task LoadAppointments()
    {
        try
        {
            isLoading = true;

            var apps = await AppointmentRepo.GetAllAsync();
            allAppointments = apps.ToList();

            // Загружаем клиентов
            foreach (var app in allAppointments)
            {
                if (!clientsCache.ContainsKey(app.ClientId))
                {
                    var clients = await ClientRepo.FindAsync(c => c.Id == app.ClientId);
                    var client = clients.FirstOrDefault();
                    if (client != null)
                        clientsCache[app.ClientId] = client;
                }
            }

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки записей: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private Client? GetClient(int clientId)
    {
        return clientsCache.TryGetValue(clientId, out var client) ? client : null;
    }

    private Service? GetService(int serviceId)
    {
        return servicesCache.TryGetValue(serviceId, out var service) ? service : null;
    }

    private string GetFilterButtonClass(string filter)
    {
        return selectedDateFilter == filter ? "active" : "";
    }

    // Методы фильтрации без лямбд в разметке
    private void FilterToday() => SetDateFilter("today");
    private void FilterTomorrow() => SetDateFilter("tomorrow");
    private void FilterWeek() => SetDateFilter("week");
    private void FilterAll() => SetDateFilter("all");

    private void SetDateFilter(string filter)
    {
        selectedDateFilter = filter;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var today = DateTime.Today;

        // Сначала применяем фильтр по дате
        var filtered = selectedDateFilter switch
        {
            "today" => allAppointments.Where(a => a.DateStart.Date == today),
            "tomorrow" => allAppointments.Where(a => a.DateStart.Date == today.AddDays(1)),
            "week" => allAppointments.Where(a => a.DateStart.Date >= today && a.DateStart.Date < today.AddDays(7)),
            _ => allAppointments.AsEnumerable()
        };

        // Потом применяем поиск
        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            var term = searchTerm.ToLower();
            filtered = filtered.Where(a =>
                (GetClient(a.ClientId)?.Name?.ToLower().Contains(term) ?? false) ||
                (GetClient(a.ClientId)?.Phone?.Contains(term) ?? false) ||
                (GetService(a.ServiceId)?.Name?.ToLower().Contains(term) ?? false)
            );
        }

        filteredAppointments = filtered.ToList();
    }

    private string GetStatusClass(AppointmentStatus status)
    {
        return status switch
        {
            AppointmentStatus.Scheduled => "status-scheduled",
            AppointmentStatus.Confirmed => "status-confirmed",
            AppointmentStatus.Completed => "status-completed",
            AppointmentStatus.Cancelled => "status-cancelled",
            AppointmentStatus.NoShow => "status-noshow",
            _ => ""
        };
    }

    private async Task UpdateStatus(int appointmentId, object? statusValue)
    {
        try
        {
            if (statusValue != null && int.TryParse(statusValue.ToString(), out int statusInt))
            {
                var appointment = allAppointments.FirstOrDefault(a => a.Id == appointmentId);
                if (appointment != null)
                {
                    appointment.Status = (AppointmentStatus)statusInt;
                    AppointmentRepo.Update(appointment);
                    await AppointmentRepo.SaveChangesAsync();
                    await LoadAppointments();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка обновления статуса: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", "Ошибка при обновлении статуса");
        }
    }

    private void EditAppointment(int appointmentId)
    {
        editingAppointment = allAppointments.FirstOrDefault(a => a.Id == appointmentId);
        if (editingAppointment != null)
        {
            editingDate = editingAppointment.DateStart;
            editingStatus = (int)editingAppointment.Status;
            editingNotes = editingAppointment.Notes ?? "";
            showEditModal = true;
        }
    }

    private async Task SaveChanges()
    {
        if (editingAppointment != null)
        {
            try
            {
                var service = GetService(editingAppointment.ServiceId);
                if (service != null)
                {
                    editingAppointment.DateStart = editingDate;
                    editingAppointment.DateEnd = editingDate.AddMinutes(service.DurationMinutes);
                    editingAppointment.Status = (AppointmentStatus)editingStatus;
                    editingAppointment.Notes = editingNotes;

                    AppointmentRepo.Update(editingAppointment);
                    await AppointmentRepo.SaveChangesAsync();

                    await LoadAppointments();
                    CloseModal();

                    await JSRuntime.InvokeVoidAsync("alert", "Запись обновлена");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка сохранения: {ex.Message}");
                await JSRuntime.InvokeVoidAsync("alert", "Ошибка при сохранении");
            }
        }
    }

    private void CloseModal()
    {
        showEditModal = false;
        editingAppointment = null;
    }

    private void DeleteAppointment(int appointmentId)
    {
        appointmentToDelete = appointmentId;
        showDeleteModal = true;
    }

    private async Task ConfirmDelete()
    {
        if (appointmentToDelete.HasValue)
        {
            try
            {
                var appointment = allAppointments.FirstOrDefault(a => a.Id == appointmentToDelete.Value);
                if (appointment != null)
                {
                    AppointmentRepo.Delete(appointment);
                    await AppointmentRepo.SaveChangesAsync();
                    await LoadAppointments();

                    await JSRuntime.InvokeVoidAsync("alert", "Запись удалена");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка удаления: {ex.Message}");
                await JSRuntime.InvokeVoidAsync("alert", "Ошибка при удалении");
            }
        }
        CloseDeleteModal();
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        appointmentToDelete = null;
    }
}
