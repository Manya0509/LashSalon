@page "/profile"
@using LashBooking.Domain.Entities
@using LashBooking.Domain.Interfaces
@using System.Linq.Expressions

@inject IRepository<Appointment> AppointmentRepo
@inject IRepository<Service> ServiceRepo
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<!-- Шапка с аватаром (как на главной) -->
<div class="avatar-wrapper-fullscreen">
    <img src="/images/avatar.jpg" class="avatar-img-fullscreen" />

    <!-- Имя клиента вместо кнопки входа -->
    <div class="client-name-header">
        <div class="client-name-badge">
            <i class="bi bi-person-circle"></i>
            <span>@clientName</span>
        </div>
    </div>

    <!-- Кнопка выхода -->
    <div class="logout-btn">
        <button class="btn-logout" @onclick="Logout">
            <i class="bi bi-box-arrow-right"></i>
            <span>Выйти</span>
        </button>
    </div>

    <div class="overlay bottom-text">
        <h2 class="name">Дарья Лукина</h2>
        <h5 class="studio">Студия LashLukina</h5>
    </div>
</div>

<!-- Основное содержимое -->
<div class="main-content">
    <div class="profile-header">
        <h3>Мои записи</h3>
        <button class="btn-back-to-main" @onclick="GoToMainPage">
            ← На главную
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-spinner">
            <div class="spinner"></div>
            <p>Загрузка записей...</p>
        </div>
    }
    else if (!appointments.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📅</div>
            <h4>У вас пока нет записей</h4>
            <p>Запишитесь онлайн прямо сейчас!</p>
            <button class="btn-book" @onclick="GoToBooking">
                Записаться онлайн
            </button>
        </div>
    }
    else
    {
        <div class="appointments-list">
            @foreach (var appointment in appointments.OrderByDescending(a => a.DateStart))
            {
                var service = GetService(appointment.ServiceId);
                var displayStatus = GetDisplayStatus(appointment);
                var statusClass = GetStatusClass(appointment);

                <div class="appointment-card @statusClass">
                    <div class="appointment-date">
                        <div class="date-badge">
                            <span class="day">@appointment.DateStart.ToString("dd")</span>
                            <span class="month">@appointment.DateStart.ToString("MMM")</span>
                        </div>
                        <div class="time-badge">
                            @appointment.DateStart.ToString("HH:mm")
                        </div>
                    </div>

                    <div class="appointment-details">
                        <h4 class="service-name">@(service?.Name ?? "Услуга не найдена")</h4>
                        <div class="appointment-meta">
                            <span class="duration">⏱️ @(service?.DurationMinutes ?? 0) мин</span>
                            <span class="price">💰 @(service?.Price.ToString("C") ?? "0 ₽")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(appointment.Notes))
                        {
                            <div class="appointment-notes">
                                <small>📝 @appointment.Notes</small>
                            </div>
                        }
                        <div class="status-badge @statusClass">
                            @displayStatus
                        </div>
                    </div>

                    @if (appointment.Status == AppointmentStatus.Scheduled ||
                                appointment.Status == AppointmentStatus.Confirmed)
                    {
                        <div class="appointment-actions">
                            <button class="btn-cancel" @onclick="() => CancelAppointment(appointment.Id)">
                                Отменить
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- Всплывающее окно подтверждения отмены -->
@if (showCancelConfirmation)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <h3>Отмена записи</h3>
            <p>Вы уверены, что хотите отменить запись?</p>
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="() => showCancelConfirmation = false">Нет</button>
                <button class="btn-danger" @onclick="ConfirmCancel">Да, отменить</button>
            </div>
        </div>
    </div>
}

@code {
    private int? currentClientId;
    private string clientName = "";
    private List<Appointment> appointments = new();
    private Dictionary<int, Service> servicesDictionary = new();
    private bool isLoading = true;
    private bool showCancelConfirmation = false;
    private int? appointmentToCancel;

    protected override async Task OnInitializedAsync()
    {
        await LoadClientData();
        await LoadServices();
        await LoadAppointments();
    }

    private async Task LoadClientData()
    {
        try
        {
            var clientIdStr = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "currentClientId");
            clientName = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "currentClientName") ?? "Гость";

            if (!string.IsNullOrEmpty(clientIdStr) && int.TryParse(clientIdStr, out int id))
            {
                currentClientId = id;
            }
            else
            {
                NavigationManager.NavigateTo("/admin/login");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки данных клиента: {ex.Message}");
            NavigationManager.NavigateTo("/admin/login");
        }
    }

    private async Task LoadServices()
    {
        try
        {
            var services = await ServiceRepo.GetAllAsync();
            servicesDictionary = services.Where(s => s.IsActive).ToDictionary(s => s.Id, s => s);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки услуг: {ex.Message}");
        }
    }

    private async Task LoadAppointments()
    {
        try
        {
            isLoading = true;

            if (currentClientId.HasValue)
            {
                var allAppointments = await AppointmentRepo.FindAsync(a =>
                    a.ClientId == currentClientId.Value);
                appointments = allAppointments
                    .OrderByDescending(a => a.DateStart)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки записей: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private Service? GetService(int serviceId)
    {
        return servicesDictionary.TryGetValue(serviceId, out var service) ? service : null;
    }

    private string GetDisplayStatus(Appointment appointment)
    {
        return appointment.Status switch
        {
            AppointmentStatus.Scheduled => "Запланирована",
            AppointmentStatus.Confirmed => "Подтверждена",
            AppointmentStatus.Completed => "Выполнена",
            AppointmentStatus.Cancelled => "Отменена",
            AppointmentStatus.NoShow => "Не явился(ась)",
            _ => "Неизвестно"
        };
    }

    private string GetStatusClass(Appointment appointment)
    {
        return appointment.Status switch
        {
            AppointmentStatus.Scheduled => "scheduled",
            AppointmentStatus.Confirmed => "confirmed",
            AppointmentStatus.Completed => "completed",
            AppointmentStatus.Cancelled => "cancelled",
            AppointmentStatus.NoShow => "noshow",
            _ => ""
        };
    }

    private void CancelAppointment(int appointmentId)
    {
        appointmentToCancel = appointmentId;
        showCancelConfirmation = true;
    }

    private async Task ConfirmCancel()
    {
        if (appointmentToCancel.HasValue)
        {
            try
            {
                var appointment = appointments.FirstOrDefault(a => a.Id == appointmentToCancel.Value);
                if (appointment != null)
                {
                    appointment.Status = AppointmentStatus.Cancelled;
                    AppointmentRepo.Update(appointment);
                    await AppointmentRepo.SaveChangesAsync();

                    await LoadAppointments();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Ошибка при отмене записи: {ex.Message}");
            }
            finally
            {
                showCancelConfirmation = false;
                appointmentToCancel = null;
            }
        }
    }

    private async Task Logout()
    {
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "currentClientId");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "currentClientName");
        NavigationManager.NavigateTo("/");
    }

    private void GoToMainPage()
    {
        NavigationManager.NavigateTo("/");
    }

    private void GoToBooking()
    {
        NavigationManager.NavigateTo("/booking");
    }
}