@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Редактировать профиль — LashLukina";

    string clientName = ViewBag.ClientName as string ?? "";
    string clientPhone = ViewBag.ClientPhone as string ?? "";
    string clientEmail = ViewBag.ClientEmail as string ?? "";
    string? editError = ViewBag.EditError as string;
}

<div class="main-content">
    <div class="edit-header">
        <h3>Редактировать профиль</h3>
        <a href="/Profile" class="btn-back">← Назад к записям</a>
    </div>

    @if (!string.IsNullOrEmpty(editError))
    {
        <div class="alert-banner danger">⚠️ @editError</div>
    }

    <div class="edit-card">
        <form method="post" action="/Profile/Edit">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="name">Имя</label>
                <input type="text" id="name" name="name" value="@clientName" required />
            </div>

            <div class="form-group">
                <label>Телефон</label>
                <input type="text" value="@clientPhone" disabled />
                <small class="form-hint">Телефон нельзя изменить — это ваш логин</small>
            </div>

            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" value="@clientEmail" placeholder="example@mail.ru" />
            </div>

            <div class="form-divider"></div>

            <h4 class="section-title">Сменить пароль</h4>
            <small class="form-hint section-hint">Оставьте пустым, если не хотите менять пароль</small>

            <div class="form-group">
                <label for="currentPassword">Текущий пароль</label>
                <input type="password" id="currentPassword" name="currentPassword" />
            </div>

            <div class="form-group">
                <label for="newPassword">Новый пароль</label>
                <input type="password" id="newPassword" name="newPassword" />
            </div>

            <div class="form-actions">
                <a href="/Profile" class="btn-cancel-edit">Отмена</a>
                <button type="submit" class="btn-save">Сохранить</button>
            </div>
        </form>
    </div>
</div>

<style>
    .main-content {
        padding: 20px;
        max-width: 600px;
        margin: 0 auto;
    }

    .edit-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding: 20px 0;
        border-bottom: 2px solid #f3f4f6;
    }

        .edit-header h3 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #2d2d2d;
            margin: 0;
        }

    .btn-back {
        padding: 10px 20px;
        background: transparent;
        border: 2px solid #808080;
        border-radius: 30px;
        color: #4d4d4d;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background: #808080;
            color: white;
            transform: translateX(-3px);
            box-shadow: 0 4px 10px rgba(128,128,128,0.3);
        }

    .alert-banner {
        padding: 14px 20px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-weight: 500;
        animation: slideUp 0.3s ease;
    }

        .alert-banner.danger {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    .edit-card {
        background: white;
        border-radius: 20px;
        padding: 35px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 1rem;
            color: #1f2937;
            transition: border-color 0.3s ease;
            box-sizing: border-box;
        }

            .form-group input:focus {
                outline: none;
                border-color: #10b981;
                box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
            }

            .form-group input:disabled {
                background: #f9fafb;
                color: #9ca3af;
                cursor: not-allowed;
            }

    .form-hint {
        display: block;
        margin-top: 6px;
        font-size: 0.85rem;
        color: #9ca3af;
    }

    .form-divider {
        height: 2px;
        background: #f3f4f6;
        margin: 30px 0;
    }

    .section-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #2d2d2d;
        margin: 0 0 5px 0;
    }

    .section-hint {
        margin-bottom: 20px;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 30px;
    }

    .btn-cancel-edit {
        padding: 12px 30px;
        background: #f3f4f6;
        border: none;
        border-radius: 30px;
        color: #4b5563;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
    }

        .btn-cancel-edit:hover {
            background: #e5e7eb;
            transform: translateY(-2px);
        }

    .btn-save {
        padding: 12px 35px;
        background: #10b981;
        border: none;
        border-radius: 30px;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(16,185,129,0.3);
    }

        .btn-save:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(16,185,129,0.4);
        }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .edit-header {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

        .edit-card {
            padding: 25px 20px;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-cancel-edit, .btn-save {
            width: 100%;
            justify-content: center;
            text-align: center;
        }
    }
</style>
