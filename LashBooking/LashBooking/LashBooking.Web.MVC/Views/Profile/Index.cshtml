@using LashBooking.Domain.Entities
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Мои записи — LashLukina";

    string clientName = ViewBag.ClientName ?? "Гость";
    var appointments = ViewBag.Appointments as List<Appointment> ?? new();
    var servicesDictionary = ViewBag.ServicesDictionary as Dictionary<int, Service> ?? new();
    string? cancelSuccess = ViewBag.CancelSuccess as string;
    string? cancelError = ViewBag.CancelError as string;
    string currentFilter = ViewBag.CurrentFilter as string ?? "upcoming";
    string? editSuccess = TempData["EditSuccess"] as string;
}
@section Head {
    <meta name="robots" content="noindex, nofollow" />
}

@* Шапка с аватаром — как в Blazor *@
<div class="avatar-wrapper-fullscreen">
    <img src="/images/avatar.jpg" class="avatar-img-fullscreen" />

    <div class="client-name-header">
        <div class="client-name-badge">
            <i class="bi bi-person-circle"></i>
            <span>@clientName</span>
        </div>
    </div>

    <a href="/Auth/Logout" class="logout-btn-link">
        <div class="btn-logout">
            <i class="bi bi-box-arrow-right"></i>
            <span>Выйти</span>
        </div>
    </a>

    <div class="overlay bottom-text">
        <h2 class="name">Дарья Лукина</h2>
        <h5 class="studio">Студия LashLukina</h5>
    </div>
</div>

<div class="main-content">
    <div class="profile-header">
        <h3>Мои записи</h3>
        <div class="profile-header-actions">
            <a href="/Profile/Edit" class="btn-edit-profile">Редактировать профиль</a>
            <a href="/" class="btn-back-to-main">← На главную</a>
        </div>
    </div>

    <div class="filter-tabs">
        <a href="/Profile?filter=upcoming" class="filter-tab @(currentFilter == "upcoming" ? "active" : "")">Предстоящие</a>
        <a href="/Profile?filter=past" class="filter-tab @(currentFilter == "past" ? "active" : "")">Прошлые</a>
        <a href="/Profile?filter=all" class="filter-tab @(currentFilter == "all" ? "active" : "")">Все</a>
    </div>


    @* Уведомления об отмене — вместо StateHasChanged() в Blazor *@
    @if (!string.IsNullOrEmpty(cancelSuccess))
    {
        <div class="alert-banner success">✅ @cancelSuccess</div>
    }
    @if (!string.IsNullOrEmpty(cancelError))
    {
        <div class="alert-banner danger">⚠️ @cancelError</div>
    }
    @if (!string.IsNullOrEmpty(editSuccess))
    {
        <div class="alert-banner success">✅ @editSuccess</div>
    }


    @if (!appointments.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📅</div>
            <h4>У вас пока нет записей</h4>
            <p>Запишитесь онлайн прямо сейчас!</p>
            <a href="/Booking" class="btn-book">Записаться онлайн</a>
        </div>
    }
    else
    {
        <div class="appointments-list">
            @foreach (var appointment in appointments)
            {
                Service? service = servicesDictionary.TryGetValue(appointment.ServiceId, out var s) ? s : null;
                string displayStatus = GetDisplayStatus(appointment.Status);
                string statusClass = GetStatusClass(appointment.Status);

                <div class="appointment-card @statusClass">
                    <div class="appointment-date">
                        <div class="date-badge">
                            <span class="day">@appointment.DateStart.ToString("dd")</span>
                            <span class="month">@appointment.DateStart.ToString("MMM")</span>
                        </div>
                        <div class="time-badge">@appointment.DateStart.ToString("HH:mm")</div>
                    </div>

                    <div class="appointment-details">
                        <h4 class="service-name">@(service?.Name ?? "Услуга не найдена")</h4>
                        <div class="appointment-meta">
                            <span class="duration">⏱️ @(service?.DurationMinutes ?? 0) мин</span>
                            <span class="price">💰 @(service?.Price.ToString("N0") ?? "0") ₽</span>
                        </div>
                        @if (!string.IsNullOrEmpty(appointment.Notes))
                        {
                            <div class="appointment-notes">
                                <small>📝 @appointment.Notes</small>
                            </div>
                        }
                        <div class="status-badge @statusClass">@displayStatus</div>
                    </div>

                    @* Кнопка отмены — только для активных записей *@
                    @if (appointment.Status == AppointmentStatus.Scheduled ||
                                appointment.Status == AppointmentStatus.Confirmed)
                    {
                        <div class="appointment-actions">
                            <button class="btn-cancel"
                                    onclick="showCancelModal(@appointment.Id)">
                                Отменить
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@* Модальное окно подтверждения отмены — было @if (showCancelConfirmation) в Blazor *@
<div class="modal-overlay" id="cancelModal" style="display:none">
    <div class="modal-card">
        <h3>Отмена записи</h3>
        <p>Вы уверены, что хотите отменить запись?</p>
        <div class="modal-actions">
            <button class="btn-secondary" onclick="hideCancelModal()">Нет</button>
            <form method="post" action="/Profile/Cancel" id="cancelForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="appointmentId" id="cancelAppointmentId" value="0" />
                <button type="submit" class="btn-danger">Да, отменить</button>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetDisplayStatus(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Scheduled => "Запланирована",
        AppointmentStatus.Confirmed => "Подтверждена",
        AppointmentStatus.Completed => "Выполнена",
        AppointmentStatus.Cancelled => "Отменена",
        AppointmentStatus.NoShow => "Не явился(ась)",
        _ => "Неизвестно"
    };

    string GetStatusClass(AppointmentStatus status) => status switch
    {
        AppointmentStatus.Scheduled => "scheduled",
        AppointmentStatus.Confirmed => "confirmed",
        AppointmentStatus.Completed => "completed",
        AppointmentStatus.Cancelled => "cancelled",
        AppointmentStatus.NoShow => "noshow",
        _ => ""
    };
}

<style>
    .avatar-wrapper-fullscreen {
        position: relative;
        width: 100%;
        height: 400px;
        overflow: hidden;
    }

    .avatar-img-fullscreen {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
    }

    .client-name-header {
        position: absolute;
        top: 20px;
        right: 130px;
        z-index: 20;
    }

    .client-name-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 30px;
        color: white;
        font-size: 14px;
        font-weight: 500;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

        .client-name-badge i {
            font-size: 18px;
        }

    .logout-btn-link {
        position: absolute;
        top: 20px;
        right: 20px;
        z-index: 20;
        text-decoration: none;
    }

    .btn-logout {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: rgba(220,38,38,0.2);
        backdrop-filter: blur(5px);
        border: 1px solid rgba(220,38,38,0.3);
        border-radius: 30px;
        color: white;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

        .btn-logout:hover {
            background: rgba(220,38,38,0.4);
            border-color: rgba(220,38,38,0.6);
            transform: translateY(-2px);
        }

        .btn-logout i {
            font-size: 18px;
        }

    .overlay.bottom-text {
        position: absolute;
        bottom: 30px;
        left: 30px;
        color: white;
    }

    .overlay .name {
        font-size: 3.2rem;
        font-weight: 800;
        margin: 0 0 5px 0;
        line-height: 1.2;
        letter-spacing: -0.02em;
        text-transform: uppercase;
        text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
    }

    .overlay .studio {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
        opacity: 0.95;
        text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
    }

    .main-content {
        padding: 20px;
        max-width: 900px;
        margin: 0 auto;
    }

    .profile-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding: 20px 0;
        border-bottom: 2px solid #f3f4f6;
    }

        .profile-header h3 {
            font-size: 1.75rem;
            font-weight: 600;
            color: #2d2d2d;
            margin: 0;
        }

    .btn-back-to-main {
        padding: 10px 20px;
        background: transparent;
        border: 2px solid #808080;
        border-radius: 30px;
        color: #4d4d4d;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

        .btn-back-to-main:hover {
            background: #808080;
            color: white;
            transform: translateX(-3px);
            box-shadow: 0 4px 10px rgba(128,128,128,0.3);
        }

    .profile-header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .btn-edit-profile {
        padding: 10px 20px;
        background: white;
        border: 2px solid #555555;
        color: #555555;
        border-radius: 30px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
    }

        .btn-edit-profile:hover {
            background: #555555;
            color: white;
        }

    .alert-banner {
        padding: 14px 20px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-weight: 500;
        animation: slideUp 0.3s ease;
    }

        .alert-banner.success {
            background: #ecfdf5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .alert-banner.danger {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

    .appointments-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .appointment-card {
        display: flex;
        align-items: center;
        gap: 25px;
        padding: 25px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        border-left: 6px solid #e5e7eb;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .appointment-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

        .appointment-card.scheduled {
            border-left-color: #3b82f6;
        }

        .appointment-card.confirmed {
            border-left-color: #10b981;
        }

        .appointment-card.completed {
            border-left-color: #9ca3af;
            opacity: 0.85;
        }

        .appointment-card.cancelled {
            border-left-color: #ef4444;
            opacity: 0.7;
        }

        .appointment-card.noshow {
            border-left-color: #f59e0b;
            opacity: 0.7;
        }

    .appointment-date {
        display: flex;
        flex-direction: column;
        align-items: center;
        min-width: 80px;
    }

    .date-badge {
        background: #f3f4f6;
        border-radius: 16px;
        padding: 12px 8px;
        text-align: center;
        width: 100%;
    }

        .date-badge .day {
            display: block;
            font-size: 28px;
            font-weight: 700;
            color: #1f2937;
            line-height: 1;
        }

        .date-badge .month {
            display: block;
            font-size: 14px;
            color: #6b7280;
            text-transform: uppercase;
            margin-top: 4px;
        }

    .time-badge {
        margin-top: 10px;
        font-size: 16px;
        font-weight: 600;
        color: #808080;
        background: rgba(128,128,128,0.1);
        padding: 4px 12px;
        border-radius: 20px;
    }

    .appointment-details {
        flex: 1;
    }

    .service-name {
        font-size: 1.3rem;
        font-weight: 600;
        color: #1f2937;
        margin: 0 0 10px 0;
    }

    .appointment-meta {
        display: flex;
        gap: 20px;
        margin-bottom: 12px;
    }

        .appointment-meta span {
            font-size: 0.95rem;
            color: #6b7280;
        }

    .appointment-notes {
        margin-bottom: 10px;
        color: #6b7280;
    }

    .status-badge {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .status-badge.scheduled {
            background: #dbeafe;
            color: #1e40af;
            border: 1px solid #93c5fd;
        }

        .status-badge.confirmed {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #6ee7b7;
        }

        .status-badge.completed {
            background: #f3f4f6;
            color: #4b5563;
            border: 1px solid #9ca3af;
        }

        .status-badge.cancelled {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .status-badge.noshow {
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #fcd34d;
        }

    .btn-cancel {
        padding: 10px 20px;
        background: transparent;
        border: 2px solid #ef4444;
        border-radius: 30px;
        color: #ef4444;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background: #ef4444;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(239,68,68,0.3);
        }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: white;
        border-radius: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .empty-icon {
        font-size: 80px;
        margin-bottom: 25px;
        opacity: 0.6;
        animation: bounce 2s infinite;
        display: block;
    }

    .empty-state h4 {
        font-size: 1.8rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 15px;
    }

    .empty-state p {
        color: #6b7280;
        margin-bottom: 30px;
        font-size: 1.1rem;
    }

    .btn-book {
        padding: 14px 40px;
        background: #10b981;
        color: white;
        border: none;
        border-radius: 40px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        box-shadow: 0 4px 15px rgba(16,185,129,0.3);
    }

        .btn-book:hover {
            background: #059669;
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(16,185,129,0.4);
            color: white;
        }

    /* Модальное окно */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        backdrop-filter: blur(5px);
        animation: fadeIn 0.3s ease;
    }

    .modal-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        max-width: 450px;
        width: 90%;
        text-align: center;
        box-shadow: 0 30px 60px rgba(0,0,0,0.3);
        animation: slideUp 0.4s ease;
    }

        .modal-card h3 {
            font-size: 1.8rem;
            font-weight: 600;
            color: #1f2937;
            margin-bottom: 15px;
        }

        .modal-card p {
            color: #6b7280;
            margin-bottom: 30px;
            font-size: 1.1rem;
        }

    .modal-actions {
        display: flex;
        gap: 15px;
        justify-content: center;
        align-items: center;
    }

    .btn-secondary {
        padding: 12px 35px;
        background: #f3f4f6;
        border: none;
        border-radius: 40px;
        color: #4b5563;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-secondary:hover {
            background: #e5e7eb;
            transform: translateY(-2px);
        }

    .btn-danger {
        padding: 12px 35px;
        background: #ef4444;
        border: none;
        border-radius: 40px;
        color: white;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(239,68,68,0.3);
    }

        .btn-danger:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(239,68,68,0.4);
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-20px);
        }
    }

    .filter-tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 25px;
    }

    .filter-tab {
        padding: 10px 24px;
        border-radius: 30px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        color: #6b7280;
        background: #f3f4f6;
        border: 2px solid transparent;
        transition: all 0.3s ease;
    }

        .filter-tab:hover {
            color: #1f2937;
            background: #e5e7eb;
        }

        .filter-tab.active {
            color: white;
            background: #808080;
            border-color: #808080;
        }

    @@media (max-width: 768px) {
        .avatar-wrapper-fullscreen {
            height: 300px;
        }

        .client-name-header {
            right: 80px;
        }

        .client-name-badge span {
            display: none;
        }

        .profile-header {
            flex-direction: column;
            gap: 15px;
            text-align: center;
        }

        .profile-header-actions {
            flex-direction: column;
            width: 100%;
        }

        .btn-edit-profile, .btn-back-to-main {
            width: 100%;
            justify-content: center;
            text-align: center;
        }

        .appointment-card {
            flex-direction: column;
            align-items: flex-start;
            padding: 20px;
        }

        .appointment-date {
            flex-direction: row;
            gap: 15px;
            width: 100%;
        }

        .date-badge {
            width: auto;
            min-width: 70px;
        }

        .time-badge {
            margin-top: 0;
            align-self: center;
        }

        .btn-cancel {
            width: 100%;
            justify-content: center;
        }

        .modal-actions {
            flex-direction: column;
        }

        .btn-secondary, .btn-danger {
            width: 100%;
        }

        .overlay .name {
            font-size: 2.5rem;
        }

        .overlay .studio {
            font-size: 1.5rem;
        }
    }

    @@media (max-width: 480px) {
        .avatar-wrapper-fullscreen {
            height: 250px;
        }

        .filter-tabs {
            flex-wrap: wrap;
            justify-content: center;
        }

        .profile-header h3 {
            font-size: 1.5rem;
        }

        .appointment-meta {
            flex-direction: column;
            gap: 8px;
        }

        .empty-icon {
            font-size: 60px;
        }

        .overlay .name {
            font-size: 2rem;
        }

        .overlay .studio {
            font-size: 1.3rem;
        }
    }
</style>

@section Scripts {
    <script>
        function showCancelModal(appointmentId) {
            document.getElementById('cancelAppointmentId').value = appointmentId;
            document.getElementById('cancelModal').style.display = 'flex';
        }

        function hideCancelModal() {
            document.getElementById('cancelModal').style.display = 'none';
        }

        // Закрываем при клике вне модалки
        document.getElementById('cancelModal').addEventListener('click', function (e) {
            if (e.target === this) hideCancelModal();
        });
    </script>
}
