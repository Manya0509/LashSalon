<!DOCTYPE html>
<html lang="ru">                                         <!-- язык страницы — русский -->
<head>
    <meta charset="utf-8" />                             <!-- кодировка UTF-8 для кириллицы -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" /> <!-- адаптивность на мобильных -->
    <title>@ViewBag.Title</title>                        <!-- заголовок вкладки — берётся из каждого View -->

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />          <!-- Bootstrap — сетка и базовые стили -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />            <!-- наши стили, asp-append-version добавляет ?v=xxx чтобы браузер не кешировал старую версию -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" /> <!-- иконки Bootstrap Icons -->
</head>
<body>
    @RenderBody()                                        <!-- сюда вставляется содержимое каждой страницы -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>              <!-- jQuery -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> <!-- Bootstrap JS -->
    @await RenderSectionAsync("Scripts", required: false)  <!-- сюда вставляется @section Scripts {} из каждой страницы, required:false — секция необязательна -->
</body>
</html>