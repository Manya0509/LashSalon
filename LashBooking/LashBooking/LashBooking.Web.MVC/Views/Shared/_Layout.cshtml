@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <meta name="description" content="@(ViewBag.Description ?? "Студия LashLukina — наращивание ресниц в Чите. Классика, 2D, 3D, коррекция. Запись онлайн.")" />
    <meta name="keywords" content="@(ViewBag.Keywords ?? "наращивание ресниц чита, классическое наращивание, 2d наращивание ресниц, 3d наращивание ресниц, коррекция ресниц чита, снятие нарощенных ресниц, салон красоты чита")" />
    <meta name="author" content="Студия LashLukina" />
    <meta name="robots" content="index, follow" />

    @{
        var ymId = Configuration["YandexMetrika:CounterId"];
    }
    @if (!string.IsNullOrWhiteSpace(ymId))
    {
        <!-- Yandex.Metrika counter -->
        <script type="text/javascript">
            (function(m,e,t,r,i,k,a){
                m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
                m[i].l=1*new Date();
                for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
                k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
            })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=@ymId', 'ym');

            ym(@ymId, 'init', {ssr:true, webvisor:true, clickmap:true, accurateTrackBounce:true, trackLinks:true});
        </script>
        <noscript><div><img src="https://mc.yandex.ru/watch/@ymId" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
        <!-- /Yandex.Metrika counter -->

        <script>
            window.ymGoal = function (name) {
                if (typeof ym !== 'undefined') {
                    ym(@ymId, 'reachGoal', name);
                }
            };
        </script>
    }

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body>
    @RenderBody()

    @if (TempData["ErrorOccurred"] != null)
    {
        bool needReload = (bool)(TempData["NeedReload"] ?? false);
        string errorMessage = TempData["ErrorMessage"]?.ToString() ?? "Что-то пошло не так.";

        <div class="modal-overlay" id="globalErrorDialog" style="display:flex">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>⚠️ Ошибка</h3>
                    <button class="modal-close"
                            onclick="document.getElementById('globalErrorDialog').style.display='none'">
                        ✕
                    </button>
                </div>
                <div class="modal-body">
                    <p>@errorMessage</p>
                </div>
                <div class="modal-footer">
                    <button class="btn-secondary"
                            onclick="document.getElementById('globalErrorDialog').style.display='none'">
                        Закрыть
                    </button>
                    @if (needReload)
                    {
                        <button class="btn-primary" onclick="location.reload()">
                            🔄 Обновить страницу
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>