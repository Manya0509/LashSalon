<!-- jQuery Validate — библиотека валидации форм, проверяет поля до отправки на сервер -->
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>

<!-- Unobtrusive Validate — связывает jQuery Validate с атрибутами ASP.NET MVC -->
