@model LashBooking.Domain.Entities.AboutInfo
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Обо мне — LashLukina";
}

<div class="back-button-container">
    <a href="/" class="back-btn">
        <span class="back-icon">←</span> Назад
    </a>
</div>

@if (Model == null)
{
    <div class="about-container">
        <p style="text-align:center; padding: 60px 20px; color: #888; font-size: 1.2rem;">
            Информация пока не заполнена
        </p>
    </div>
}
else
{
    <div class="about-container">

        <div class="about-header">
            <div class="profile-image-wrapper">
                @if (!string.IsNullOrEmpty(Model.PhotoFileName))
                {
                    <img src="/images/@Model.PhotoFileName" alt="@Model.MasterName" class="profile-image" />
                }
                else
                {
                    <img src="/images/master.png" alt="@Model.MasterName" class="profile-image" />
                }
            </div>
            <div class="profile-title">
                <h1 class="master-name">@Model.MasterName</h1>
                <p class="master-role">@Model.Role</p>
                <div class="experience-badge">@Model.Experience</div>
            </div>
        </div>

        <div class="quote-block">
            <p class="quote-text">
                "@Model.Quote"
            </p>
        </div>

        <div class="about-grid">
            <div class="about-card">
                <h3>✨ Обо мне</h3>
                @foreach (var paragraph in Model.AboutText.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                {
                    <p>@paragraph.Trim()</p>
                }
            </div>

            <div class="about-card">
                <h3>🎓 Образование</h3>
                <ul class="education-list">
                    @foreach (var line in Model.EducationText.Split('\n', StringSplitOptions.RemoveEmptyEntries))
                    {
                        <li>✓ @line.Trim()</li>
                    }
                </ul>
            </div>
        </div>

        <h3 class="section-title">Почему выбирают меня</h3>
        <div class="advantages-grid">
            <div class="advantage-item">
                <div class="advantage-icon">🔬</div>
                <h4>Стерильность</h4>
                <p>Все инструменты проходят многоступенчатую обработку</p>
            </div>
            <div class="advantage-item">
                <div class="advantage-icon">💎</div>
                <h4>Материалы</h4>
                <p>Только премиальные бренды: Lovely, Enigma, Be Perfect</p>
            </div>
            <div class="advantage-item">
                <div class="advantage-icon">⏱️</div>
                <h4>Скорость</h4>
                <p>Наращивание за 1.5-2 часа без потери качества</p>
            </div>
            <div class="advantage-item">
                <div class="advantage-icon">❤️</div>
                <h4>Гарантия</h4>
                <p>Даю гарантию на работу до 3-х недель</p>
            </div>
        </div>

        <h3 class="section-title">Мои сертификаты</h3>

        <div class="certificates-grid">
            <div class="certificate-item">
                <img src="/images/Certificate/cert1.jpg" alt="Сертификат 1" class="certificate-image" />
            </div>
            <div class="certificate-item">
                <img src="/images/Certificate/cert3.jpg" alt="Сертификат 2" class="certificate-image" />
            </div>
            <div class="certificate-item">
                <img src="/images/Certificate/cert2.jpg" alt="Сертификат 3" class="certificate-image" />
            </div>
            <div class="certificate-item">
                <img src="/images/Certificate/cert4.jpg" alt="Сертификат 4" class="certificate-image" />
            </div>
            <div class="certificate-item">
                <img src="/images/Certificate/cert5.jpg" alt="Сертификат 5" class="certificate-image" />
            </div>
        </div>

        <div class="certificate-row-full">
            <div class="certificate-item certificate-horizontal">
                <img src="/images/Certificate/cert6.jpg" alt="Сертификат 6" class="certificate-image-horizontal" />
            </div>
        </div>

        <div class="contact-section">
            <h3 class="section-title">Как со мной связаться</h3>
            <div class="contact-links">
                @if (!string.IsNullOrEmpty(Model.WhatsAppLink))
                {
                    <a href="@Model.WhatsAppLink" class="contact-link whatsapp" target="_blank">
                        <i class="bi bi-whatsapp"></i> WhatsApp
                    </a>
                }
                @if (!string.IsNullOrEmpty(Model.TelegramLink))
                {
                    <a href="@Model.TelegramLink" class="contact-link telegram" target="_blank">
                        <i class="bi bi-telegram"></i> Telegram
                    </a>
                }
                <button class="contact-link phone" onclick="showPhone()">
                    <i class="bi bi-telephone-fill"></i> Позвонить
                </button>
            </div>

            <div class="info-block">
                <p><i class="bi bi-geo-alt-fill"></i> @Model.Address</p>
                <p><i class="bi bi-clock-fill"></i> @Model.WorkingHours</p>
            </div>

            <div class="phone-popup" id="phonePopup">
                <div class="phone-popup-content">
                    <i class="bi bi-telephone-fill"></i>
                    <span class="phone-number">@Model.Phone</span>
                    <button class="phone-popup-close" onclick="hidePhone()">✕</button>
                </div>
            </div>
        </div>

    </div>
}

<style>
    .back-button-container {
        max-width: 1200px;
        margin: 20px auto 0;
        padding: 0 20px;
    }

    .back-btn {
        background: transparent;
        color: #444;
        border: 2px solid #333;
        border-radius: 30px;
        padding: 8px 20px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .back-btn:hover {
            background: #555;
            color: white;
            transform: translateX(-3px);
        }

    .back-icon {
        font-size: 1.2rem;
        line-height: 1;
    }

    .about-container {
        max-width: 1200px;
        margin: 0 auto 60px;
        padding: 0 20px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .about-header {
        display: flex;
        align-items: center;
        gap: 50px;
        margin: 40px 0 60px;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 40px;
        border-radius: 30px;
    }

    .profile-image-wrapper {
        flex-shrink: 0;
        width: 250px;
        height: 250px;
        border-radius: 50%;
        overflow: hidden;
        border: 5px solid white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .profile-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
    }


    .profile-title {
        flex: 1;
    }

    .master-name {
        font-size: 3rem;
        font-weight: 700;
        color: #2d2d2d;
        margin: 0 0 10px;
        letter-spacing: -0.02em;
    }

    .master-role {
        font-size: 1.4rem;
        color: #666;
        margin: 0 0 20px;
    }

    .experience-badge {
        display: inline-block;
        background: #444;
        color: white;
        padding: 8px 24px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 1rem;
    }

    .quote-block {
        background: white;
        padding: 40px;
        border-radius: 30px;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        border-left: 6px solid #555;
    }

    .quote-text {
        font-size: 1.6rem;
        font-style: italic;
        color: #333;
        text-align: center;
        margin: 0;
        line-height: 1.5;
    }

    .about-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 30px;
        margin-bottom: 50px;
    }

    .about-card {
        background: white;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid #f0f0f0;
    }

        .about-card h3 {
            font-size: 1.8rem;
            color: #2d2d2d;
            margin: 0 0 20px;
            font-weight: 600;
        }

        .about-card p {
            color: #555;
            line-height: 1.8;
            margin-bottom: 15px;
            font-size: 1.1rem;
        }

    .education-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .education-list li {
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
            color: #555;
            font-size: 1.1rem;
        }

            .education-list li:last-child {
                border-bottom: none;
            }

    .section-title {
        font-size: 2.2rem;
        font-weight: 600;
        color: #2d2d2d;
        text-align: center;
        margin: 50px 0 30px;
    }

    .advantages-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
        margin-bottom: 50px;
    }

    .advantage-item {
        background: white;
        padding: 30px 20px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.03);
        border: 1px solid #f0f0f0;
        transition: transform 0.3s ease;
    }

        .advantage-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(79, 70, 229, 0.1);
        }

    .advantage-icon {
        font-size: 3rem;
        margin-bottom: 15px;
    }

    .advantage-item h4 {
        font-size: 1.3rem;
        color: #2d2d2d;
        margin: 0 0 10px;
    }

    .advantage-item p {
        color: #666;
        margin: 0;
        line-height: 1.5;
    }

    .certificates-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 25px;
        margin-bottom: 25px;
    }

    .certificate-item {
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        aspect-ratio: 3/4;
        cursor: pointer;
    }

    .certificate-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .certificate-item:hover .certificate-image {
        transform: scale(1.05);
    }

    .certificate-row-full {
        width: 100%;
        margin: 0 0 50px;
    }

    .certificate-horizontal {
        aspect-ratio: 16/9 !important;
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
    }

    .certificate-image-horizontal {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        transition: transform 0.4s ease;
        border-radius: 15px;
    }

    .contact-section {
        background: white;
        padding: 40px;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        margin-top: 30px;
    }

    .contact-links {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        justify-content: center;
        margin-bottom: 30px;
    }

    .contact-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 30px;
        border-radius: 50px;
        font-size: 1.1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        border: none;
    }

        .contact-link.whatsapp {
            background: #25D366;
            color: white;
        }

            .contact-link.whatsapp:hover {
                background: #128C7E;
                transform: translateY(-2px);
                color: white;
            }

        .contact-link.telegram {
            background: #2AABEE;
            color: white;
        }

            .contact-link.telegram:hover {
                background: #229ED9;
                transform: translateY(-2px);
                color: white;
            }

        .contact-link.phone {
            background: #4f46e5;
            color: white;
        }

            .contact-link.phone:hover {
                background: #4338ca;
                transform: translateY(-2px);
            }

    .info-block {
        text-align: center;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 2px solid #f0f0f0;
    }

        .info-block p {
            font-size: 1.2rem;
            color: #555;
            margin: 10px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .info-block i {
            color: #444;
        }

    .phone-popup {
        position: fixed;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%) translateY(100px);
        background: white;
        border-radius: 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        padding: 12px 24px;
        z-index: 1000;
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        border: 1px solid #e0e0e0;
        pointer-events: none;
    }

        .phone-popup.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
            pointer-events: all;
        }

    .phone-popup-content {
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .phone-popup-content i {
            color: #28a745;
            font-size: 20px;
        }

    .phone-number {
        font-size: 18px;
        font-weight: 600;
        color: #333;
    }

    .phone-popup-close {
        background: none;
        border: none;
        color: #999;
        font-size: 18px;
        cursor: pointer;
        padding: 0 5px;
    }

        .phone-popup-close:hover {
            color: #333;
        }

    @@media screen and (max-width: 992px) {
        .about-header {
            flex-direction: column;
            text-align: center;
            gap: 30px;
            padding: 30px;
        }

        .profile-image-wrapper {
            width: 200px;
            height: 200px;
        }

        .master-name {
            font-size: 2.5rem;
        }

        .advantages-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media screen and (max-width: 768px) {
        .about-grid {
            grid-template-columns: 1fr;
        }

        .certificates-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .contact-links {
            flex-direction: column;
            align-items: center;
        }

        .contact-link {
            width: 100%;
            justify-content: center;
        }

        .master-name {
            font-size: 2rem;
        }

        .quote-text {
            font-size: 1.3rem;
        }
    }

    @@media screen and (max-width: 576px) {
        .advantages-grid {
            grid-template-columns: 1fr;
        }

        .certificates-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media screen and (max-width: 480px) {
        .master-name {
            font-size: 1.8rem;
        }

        .quote-block {
            padding: 20px;
        }

        .quote-text {
            font-size: 1.1rem;
        }

        .about-card {
            padding: 20px;
        }

        .contact-section {
            padding: 20px 15px;
        }

        .section-title {
            font-size: 1.5rem;
        }
    }
</style>

<script>
    function showPhone() {
        document.getElementById('phonePopup').classList.add('show');
    }

    function hidePhone() {
        document.getElementById('phonePopup').classList.remove('show');
    }

    document.addEventListener('click', function (event) {
        var popup = document.getElementById('phonePopup');
        if (!popup) return;
        var phoneBtn = event.target.closest('.contact-link.phone');
        if (!phoneBtn && !popup.contains(event.target)) {
            popup.classList.remove('show');
        }
    });
</script>
