    .block-badge {
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.85rem;
        font-weight: 500;
    }

        .block-badge.day {
            background: #fef2f2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .block-badge.hour {
            background: #fff3e0;
            color: #92400e;
            border: 1px solid #fed7aa;
        }
</style>

@section Scripts {
    <script>
        // ===== ЗАПИСИ =====
        function updateStatus(apptId, status, selectEl) {
            updateSelectStyle(selectEl);
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            fetch('/Admin/UpdateAppointmentStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'appointmentId=' + apptId + '&status=' + status + '&__RequestVerificationToken=' + encodeURIComponent(token)
            });
        }

        function updateSelectStyle(sel) {
            var classes = { 1:'status-scheduled', 2:'status-confirmed', 3:'status-completed', 4:'status-cancelled', 5:'status-noshow' };
            sel.className = 'status-select ' + (classes[sel.value] || '');
        }

        function filterAppointments(term) {
            term = term.toLowerCase();
            document.querySelectorAll('.appt-row').forEach(function(row) {
                var match = !term
                    || row.dataset.client.includes(term)
                    || row.dataset.phone.includes(term)
                    || row.dataset.service.includes(term);
                row.style.display = match ? '' : 'none';
            });
        }

        function openEditModal(id, dateStart, status, notes) {
            document.getElementById('editAppointmentId').value = id;
            document.getElementById('editDateStart').value = dateStart;
            document.getElementById('editStatus').value = status;
            document.getElementById('editNotes').value = notes;
            document.getElementById('editModal').style.display = 'flex';
        }

        function closeEditModal() {
            document.getElementById('editModal').style.display = 'none';
        }

        function confirmDeleteAppt(id) {
            if (confirm('Удалить эту запись? Действие нельзя отменить.')) {
                document.getElementById('deleteApptId').value = id;
                document.getElementById('deleteApptForm').submit();
            }
        }

                // ===== ЗАПИСИ СОРТИРОВКА =====
        let apptSortState = { col: null, asc: true };

        function sortAppointments(col) {
            const tbody = document.querySelector('#appointmentsTable tbody');
            if (!tbody) return;

            apptSortState.asc = apptSortState.col === col ? !apptSortState.asc : true;
            apptSortState.col = col;

            ['date','client','service','price'].forEach(c => {
                const el = document.getElementById('appt-sort-' + c);
                if (el) el.textContent = '↕';
            });
            const icon = document.getElementById('appt-sort-' + col);
            if (icon) icon.textContent = apptSortState.asc ? '↑' : '↓';

            const rows = Array.from(tbody.querySelectorAll('.appt-row'));
            rows.sort((a, b) => {
                let valA = a.dataset[col] ?? '';
                let valB = b.dataset[col] ?? '';

                if (col === 'price' || col === 'date') {
                    valA = parseFloat(valA) || 0;
                    valB = parseFloat(valB) || 0;
                    return apptSortState.asc ? valA - valB : valB - valA;
                }

                return apptSortState.asc
                    ? valA.localeCompare(valB, 'ru')
                    : valB.localeCompare(valA, 'ru');
            });

            rows.forEach(r => tbody.appendChild(r));
        }

        // ===== ОТЗЫВЫ =====
        function switchReviewTab(tab) {
            document.getElementById('reviewsPending').style.display  = tab === 'pending'  ? 'flex' : 'none';
            document.getElementById('reviewsApproved').style.display = tab === 'approved' ? 'flex' : 'none';
            document.getElementById('reviewsAll').style.display      = tab === 'all'      ? 'flex' : 'none';
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            var map = { pending: 'tabPending', approved: 'tabApproved', all: 'tabAll' };
            document.getElementById(map[tab])?.classList.add('active');
        }

        // ===== КЛИЕНТЫ =====
        function filterClients(term) {
            term = term.toLowerCase();
            document.querySelectorAll('.client-row').forEach(function(row) {
                var match = !term
                    || row.dataset.name.includes(term)
                    || row.dataset.phone.includes(term);
                row.style.display = match ? '' : 'none';
            });
        }

                let sortState = { col: null, asc: true };

        function sortClients(col) {
            const tbody = document.querySelector('#clientsTable tbody');
            if (!tbody) return;

            sortState.asc = sortState.col === col ? !sortState.asc : true;
            sortState.col = col;

            // Сбрасываем все иконки
            ['name','phone','count','date'].forEach(c => {
                const el = document.getElementById('sort-' + c);
                if (el) el.textContent = '↕';
            });
            const icon = document.getElementById('sort-' + col);
            if (icon) icon.textContent = sortState.asc ? '↑' : '↓';

            const rows = Array.from(tbody.querySelectorAll('.client-row'));
            rows.sort((a, b) => {
                let valA = a.dataset[col] ?? '';
                let valB = b.dataset[col] ?? '';

                if (col === 'count') {
                    valA = parseInt(valA) || 0;
                    valB = parseInt(valB) || 0;
                    return sortState.asc ? valA - valB : valB - valA;
                }

                return sortState.asc
                    ? valA.localeCompare(valB, 'ru')
                    : valB.localeCompare(valA, 'ru');
            });

            rows.forEach(r => tbody.appendChild(r));
        }

        // ===== УСЛУГИ =====
        function openServiceModal(id, name, desc, price, duration) {
            document.getElementById('serviceId').value = id;
            document.getElementById('serviceName').value = name;
            document.getElementById('serviceDescription').value = desc;
            document.getElementById('servicePrice').value = price;
            document.getElementById('serviceDuration').value = duration;
            document.getElementById('serviceModalTitle').innerHTML =
                '<i class="bi bi-grid"></i> ' + (id == 0 ? 'Новая услуга' : 'Редактирование услуги');
            document.getElementById('serviceModal').style.display = 'flex';
        }

        function closeServiceModal() {
            document.getElementById('serviceModal').style.display = 'none';
        }

                // ===== УСЛУГИ СОРТИРОВКА =====
        let svcSortState = { col: null, asc: true };

        function sortServices(col) {
            const tbody = document.querySelector('#servicesTable tbody');
            if (!tbody) return;

            svcSortState.asc = svcSortState.col === col ? !svcSortState.asc : true;
            svcSortState.col = col;

            ['name','price','duration'].forEach(c => {
                const el = document.getElementById('svc-sort-' + c);
                if (el) el.textContent = '↕';
            });
            const icon = document.getElementById('svc-sort-' + col);
            if (icon) icon.textContent = svcSortState.asc ? '↑' : '↓';

            const rows = Array.from(tbody.querySelectorAll('.svc-row'));
            rows.sort((a, b) => {
                let valA = a.dataset[col] ?? '';
                let valB = b.dataset[col] ?? '';

                if (col === 'price' || col === 'duration') {
                    valA = parseFloat(valA) || 0;
                    valB = parseFloat(valB) || 0;
                    return svcSortState.asc ? valA - valB : valB - valA;
                }

                return svcSortState.asc
                    ? valA.localeCompare(valB, 'ru')
                    : valB.localeCompare(valA, 'ru');
            });

            rows.forEach(r => tbody.appendChild(r));
        }
    </script>
}
