        }

    .btn-secondary {
        background: #f5f5f5;
        color: #555;
        border: 1px solid #ddd;
        padding: 10px 24px;
        border-radius: 6px;
        font-size: 0.95rem;
        cursor: pointer;
    }

        .btn-secondary:hover {
            background: #eee;
        }

    .btn-danger {
        background: #dc3545;
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 6px;
        font-size: 0.95rem;
        cursor: pointer;
    }

        .btn-danger:hover {
