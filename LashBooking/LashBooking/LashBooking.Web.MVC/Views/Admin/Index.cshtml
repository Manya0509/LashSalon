@using LashBooking.Domain.Entities
@using Microsoft.AspNetCore.Html
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Панель администратора";

    string activeTab = ViewBag.ActiveTab ?? "appointments";
    int todayAppointments = ViewBag.TodayAppointments ?? 0;
    int upcomingAppointments = ViewBag.UpcomingAppointments ?? 0;
    int pendingReviews = ViewBag.PendingReviews ?? 0;
    int totalClients = ViewBag.TotalClients ?? 0;
    string? message = ViewBag.Message as string;
    bool isSuccess = ViewBag.IsSuccess ?? true;
}

@Html.AntiForgeryToken()

<div class="back-button-container">
    <a href="/" class="back-btn"><span class="back-icon">←</span> На сайт</a>
    <a href="/Admin/Logout" class="logout-admin-btn">
        <i class="bi bi-box-arrow-right"></i> Выйти
    </a>
</div>

<div class="admin-container">
    <h1 class="admin-title">
        <i class="bi bi-shield-lock"></i> Панель администратора
    </h1>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert-banner @(isSuccess ? "success" : "danger")">
            @(isSuccess ? "✅" : "⚠️") @message
        </div>
    }

    @* Статистика *@
    <div class="stats-grid">
        <a href="/Admin/Index?tab=appointments" class="stat-card">
            <div class="stat-icon">📅</div>
            <div class="stat-content">
                <span class="stat-value">@todayAppointments</span>
                <span class="stat-label">Записей на сегодня</span>
            </div>
        </a>
        <a href="/Admin/Index?tab=appointments" class="stat-card">
            <div class="stat-icon">⏳</div>
            <div class="stat-content">
                <span class="stat-value">@upcomingAppointments</span>
                <span class="stat-label">Предстоящих записей</span>
            </div>
        </a>
        <a href="/Admin/Index?tab=reviews" class="stat-card">
            <div class="stat-icon">📝</div>
            <div class="stat-content">
                <span class="stat-value">@pendingReviews</span>
                <span class="stat-label">Отзывов на модерации</span>
            </div>
        </a>
        <a href="/Admin/Index?tab=clients" class="stat-card">
            <div class="stat-icon">👥</div>
            <div class="stat-content">
                <span class="stat-value">@totalClients</span>
                <span class="stat-label">Всего клиентов</span>
            </div>
        </a>
    </div>

    @* Навигация *@
    <div class="admin-nav">
        <a href="/Admin/Index?tab=appointments" class="nav-btn @(activeTab == "appointments" ? "active" : "")">
            <i class="bi bi-calendar-check"></i> Записи
            @if (todayAppointments > 0)
            {
                <span class="badge">@todayAppointments</span>
            }
        </a>
        <a href="/Admin/Index?tab=reviews" class="nav-btn @(activeTab == "reviews" ? "active" : "")">
            <i class="bi bi-star"></i> Отзывы
            @if (pendingReviews > 0)
            {
                <span class="badge warning">@pendingReviews</span>
            }
        </a>
        <a href="/Admin/Index?tab=clients" class="nav-btn @(activeTab == "clients" ? "active" : "")">
            <i class="bi bi-people"></i> Клиенты
        </a>
        <a href="/Admin/Index?tab=services" class="nav-btn @(activeTab == "services" ? "active" : "")">
            <i class="bi bi-grid"></i> Услуги
        </a>
        <a href="/Admin/Index?tab=schedule" class="nav-btn @(activeTab == "schedule" ? "active" : "")">
            <i class="bi bi-calendar-x"></i> Расписание
        </a>
    </div>

    <div class="admin-content">

        @* ==================== ЗАПИСИ ==================== *@
        @if (activeTab == "appointments")
        {
            var appointments = ViewBag.Appointments as List<Appointment> ?? new List<Appointment>();
            var clientsDict = ViewBag.AppointmentsClientsDict as Dictionary<int, Client> ?? new Dictionary<int, Client>();
            var servicesDict = ViewBag.AppointmentsServicesDict as Dictionary<int, Service> ?? new Dictionary<int, Service>();
            string apptFilter = ViewBag.AppointmentFilter ?? "today";
            string apptSearch = ViewBag.AppointmentSearch ?? "";

            <div class="management-section">
                <div class="section-header">
                    <h2><i class="bi bi-calendar-check"></i> Управление записями</h2>
                    <div class="header-actions">
                        <a href="/Admin/FilterAppointments?filter=today" class="filter-btn @(apptFilter == "today" ? "active" : "")">Сегодня</a>
                        <a href="/Admin/FilterAppointments?filter=tomorrow" class="filter-btn @(apptFilter == "tomorrow" ? "active" : "")">Завтра</a>
                        <a href="/Admin/FilterAppointments?filter=week" class="filter-btn @(apptFilter == "week" ? "active" : "")">Неделя</a>
                        <a href="/Admin/FilterAppointments?filter=all" class="filter-btn @(apptFilter == "all" ? "active" : "")">Все</a>
                        <a href="/Admin/ExportAppointments" class="filter-btn" title="Экспорт в Excel">
                            <i class="bi bi-file-earmark-excel"></i> Экспорт
                        </a>
                    </div>
                </div>

                <div class="appointments-stats">
                    <div class="stat-item"><span class="stat-label">Всего:</span><span class="stat-value">@(ViewBag.AppointmentsTotalCount ?? 0)</span></div>
                    <div class="stat-item"><span class="stat-label">Сегодня:</span><span class="stat-value today">@(ViewBag.AppointmentsTodayCount ?? 0)</span></div>
                    <div class="stat-item"><span class="stat-label">Запланировано:</span><span class="stat-value scheduled">@(ViewBag.AppointmentsScheduledCount ?? 0)</span></div>
                    <div class="stat-item"><span class="stat-label">Подтверждено:</span><span class="stat-value confirmed">@(ViewBag.AppointmentsConfirmedCount ?? 0)</span></div>
                    <div class="stat-item"><span class="stat-label">Выполнено:</span><span class="stat-value completed">@(ViewBag.AppointmentsCompletedCount ?? 0)</span></div>
                    <div class="stat-item"><span class="stat-label">Отменено:</span><span class="stat-value cancelled">@(ViewBag.AppointmentsCancelledCount ?? 0)</span></div>
                </div>

                <div class="search-section">
                    <input type="text" class="search-input" id="apptSearchInput"
                           value="@apptSearch"
                           placeholder="🔍 Поиск по имени, телефону или услуге..."
                           oninput="filterAppointments(this.value)" />
                </div>

                @if (!appointments.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">📅</div>
                        <h4>Записи не найдены</h4>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="admin-table" id="appointmentsTable">
                            <thead>
                                <tr>
                                    <th class="sortable" onclick="sortAppointments('date')">Дата и время <span id="appt-sort-date">↕</span></th>
                                    <th class="sortable" onclick="sortAppointments('client')">Клиент <span id="appt-sort-client">↕</span></th>
                                    <th>Телефон</th>
                                    <th class="sortable" onclick="sortAppointments('service')">Услуга <span id="appt-sort-service">↕</span></th>
                                    <th>Длит.</th>
                                    <th class="sortable" onclick="sortAppointments('price')">Цена <span id="appt-sort-price">↕</span></th>
                                    <th>Статус</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var appt in appointments)
                                {
                                    clientsDict.TryGetValue(appt.ClientId, out Client? apptClient);
                                    servicesDict.TryGetValue(appt.ServiceId, out Service? apptService);

                                    string sc = appt.Status switch
                                    {
                                        AppointmentStatus.Scheduled => "status-scheduled",
                                        AppointmentStatus.Confirmed => "status-confirmed",
                                        AppointmentStatus.Completed => "status-completed",
                                        AppointmentStatus.Cancelled => "status-cancelled",
                                        AppointmentStatus.NoShow => "status-noshow",
                                        _ => ""
                                    };

                                    string clientName = apptClient?.Name ?? "—";
                                    string clientPhone = apptClient?.Phone ?? "—";
                                    string serviceName = apptService?.Name ?? "—";
                                    int duration = apptService?.DurationMinutes ?? 0;
                                    decimal price = apptService?.Price ?? 0;
                                    string dateStr = appt.DateStart.ToString("yyyy-MM-ddTHH:mm");
                                    string notes = (appt.Notes ?? "").Replace("'", "\\'").Replace("\n", " ");

                                    <tr class="appt-row"
                                        data-client="@clientName.ToLower()"
                                        data-phone="@clientPhone"
                                        data-service="@serviceName.ToLower()"
                                        data-date="@appt.DateStart.ToString("yyyyMMddHHmm")"
                                        data-price="@price">
                                        <td class="time-cell">
                                            <strong>@appt.DateStart.ToString("HH:mm")</strong>
                                            <small>@appt.DateStart.ToString("dd.MM.yyyy")</small>
                                        </td>
                                        <td>@clientName</td>
                                        <td>@clientPhone</td>
                                        <td>@serviceName</td>
                                        <td>@duration мин</td>
                                        <td class="price-cell">@price.ToString("C")</td>
                                        <td>
                                            <select class="status-select @sc"
                                                    onchange="updateStatus(@appt.Id, this.value, this)">
                                                <option value="1">Запланирована</option>
                                                <option value="2">Подтверждена</option>
                                                <option value="3">Выполнена</option>
                                                <option value="4">Отменена</option>
                                                <option value="5">Не явился</option>
                                            </select>
                                        </td>
                                        <td class="actions-cell">
                                            <button class="btn-icon edit"
                                                    onclick="openEditModal(@appt.Id, '@dateStr', @((int)appt.Status), '@notes')"
                                                    title="Редактировать">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn-icon delete"
                                                    onclick="confirmDeleteAppt(@appt.Id)"
                                                    title="Удалить">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* Устанавливаем выбранный статус через JS после рендера *@
            <script>
                                // Когда страница загрузилась — устанавливаем статусы для всех записей
                document.addEventListener('DOMContentLoaded', function () {
                    // Razor-цикл: для каждой записи из C# генерирует строку JavaScript
                    // Например: setSelectValue(5, 3); setSelectValue(12, 1);
                    @foreach (var appt in appointments)
                    {
                            <text>
                            setSelectValue(@appt.Id, @((int)appt.Status));
                            </text>
                    }
                });

                // Находит select нужной записи по ID и устанавливает нужное значение
                function setSelectValue(apptId, status) {
                    var rows = document.querySelectorAll('.appt-row');
                    rows.forEach(function(row) {
                        var sel = row.querySelector('.status-select');
                        // Ищем select у которого в onchange есть нужный ID записи
                        if (sel && sel.getAttribute('onchange').includes('(' + apptId + ',')) {
                            sel.value = status;          // устанавливаем значение
                            updateSelectStyle(sel);      // красим в нужный цвет
                        }
                    });
                }

                // Красит select в цвет соответствующий статусу
                function updateSelectStyle(sel) {
                    sel.className = 'status-select';     // сбрасываем старые классы
                    var classes = {
                        1: 'status-scheduled',           // Запланирована — голубой
                        2: 'status-confirmed',           // Подтверждена  — зелёный
                        3: 'status-completed',           // Выполнена     — серый
                        4: 'status-cancelled',           // Отменена      — красный
                        5: 'status-noshow'               // Не явился     — жёлтый
                    };
                    sel.classList.add(classes[sel.value] || '');  // добавляем класс нужного цвета
                }
            </script>

            @* Модалка редактирования записи *@
            <div class="modal-overlay" id="editModal" style="display:none" onclick="if(event.target===this)closeEditModal()">
                <div class="modal-content">
                    <div class="modal-header">
                        <h3><i class="bi bi-pencil-square"></i> Редактирование записи</h3>
                        <button class="modal-close" onclick="closeEditModal()">✕</button>
                    </div>
                    <form method="post" action="/Admin/SaveAppointment">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" id="editAppointmentId" />
                        <div class="modal-body">
                            <div class="form-group">
                                <label class="form-label">Дата и время</label>
                                <input type="datetime-local" class="form-control" name="dateStart" id="editDateStart" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Статус</label>
                                <select class="form-control" name="status" id="editStatus">
                                    <option value="1">Запланирована</option>
                                    <option value="2">Подтверждена</option>
                                    <option value="3">Выполнена</option>
                                    <option value="4">Отменена</option>
                                    <option value="5">Не явился</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Заметки</label>
                                <textarea class="form-control" name="notes" id="editNotes" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn-secondary" onclick="closeEditModal()">Отмена</button>
                            <button type="submit" class="btn-primary">Сохранить</button>
                        </div>
                    </form>
                </div>
            </div>

            @* Скрытая форма удаления *@
            <form method="post" action="/Admin/DeleteAppointment" id="deleteApptForm" style="display:none">
                @Html.AntiForgeryToken()
                <input type="hidden" name="appointmentId" id="deleteApptId" />
            </form>
        }

        @* ==================== ОТЗЫВЫ ==================== *@
        else if (activeTab == "reviews")
        {
            var allReviews = ViewBag.AllReviews as List<Review> ?? new List<Review>();
            var pendingList = ViewBag.PendingReviewsList as List<Review> ?? new List<Review>();
            var approvedList = ViewBag.ApprovedReviewsList as List<Review> ?? new List<Review>();
            double avgRating = ViewBag.AverageRating != null ? (double)ViewBag.AverageRating : 0.0;

            <div class="management-section">
                <div class="section-header">
                    <h2><i class="bi bi-star"></i> Управление отзывами</h2>
                </div>

                <div class="reviews-stats">
                    <div class="stat-card-small">
                        <div class="stat-icon">⭐</div>
                        <div class="stat-info">
                            <span class="stat-value">@avgRating.ToString("F1")</span>
                            <span class="stat-label">Средний рейтинг</span>
                        </div>
                    </div>
                    <div class="stat-card-small">
                        <div class="stat-icon">📝</div>
                        <div class="stat-info">
                            <span class="stat-value">@allReviews.Count</span>
                            <span class="stat-label">Всего отзывов</span>
                        </div>
                    </div>
                    <div class="stat-card-small">
                        <div class="stat-icon">⏳</div>
                        <div class="stat-info">
                            <span class="stat-value">@pendingList.Count</span>
                            <span class="stat-label">На модерации</span>
                        </div>
                    </div>
                    <div class="stat-card-small">
                        <div class="stat-icon">✅</div>
                        <div class="stat-info">
                            <span class="stat-value">@approvedList.Count</span>
                            <span class="stat-label">Одобрено</span>
                        </div>
                    </div>
                </div>

                <div class="reviews-tabs">
                    <button class="tab-btn active" id="tabPending" onclick="switchReviewTab('pending')">
                        На модерации
                        @if (pendingList.Count > 0)
                        {
                            <span class="badge">@pendingList.Count</span>
                        }
                    </button>
                    <button class="tab-btn" id="tabApproved" onclick="switchReviewTab('approved')">Одобренные</button>
                    <button class="tab-btn" id="tabAll" onclick="switchReviewTab('all')">Все</button>
                </div>

                @* Вкладка: На модерации *@
                <div id="reviewsPending" class="reviews-list">
                    @if (!pendingList.Any())
                    {
                        <div class="empty-state"><div class="empty-icon">📭</div><h4>Нет отзывов на модерации</h4></div>
                    }
                    else
                    {
                        @foreach (var r in pendingList)
                        {
                            @await Html.PartialAsync("_ReviewCard", r)
                        }
                    }
                </div>

                @* Вкладка: Одобренные *@
                <div id="reviewsApproved" class="reviews-list" style="display:none">
                    @if (!approvedList.Any())
                    {
                        <div class="empty-state"><div class="empty-icon">📭</div><h4>Нет одобренных отзывов</h4></div>
                    }
                    else
                    {
                        @foreach (var r in approvedList)
                        {
                            @await Html.PartialAsync("_ReviewCard", r)
                        }
                    }
                </div>

                @* Вкладка: Все *@
                <div id="reviewsAll" class="reviews-list" style="display:none">
                    @if (!allReviews.Any())
                    {
                        <div class="empty-state"><div class="empty-icon">📭</div><h4>Отзывов пока нет</h4></div>
                    }
                    else
                    {
                        @foreach (var r in allReviews)
                        {
                            @await Html.PartialAsync("_ReviewCard", r)
                        }
                    }
                </div>
            </div>
        }

        @* ==================== КЛИЕНТЫ ==================== *@
        else if (activeTab == "clients")
        {
            var clients = ViewBag.Clients as List<Client> ?? new List<Client>();
            var appointmentCounts = ViewBag.AppointmentCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
            int totalCount = ViewBag.TotalClientsCount ?? 0;
            string clientSearch = ViewBag.ClientSearch ?? "";

            <div class="management-section">
                <div class="section-header">
                    <h2><i class="bi bi-people"></i> Управление клиентами</h2>
                    <a href="/Admin/Index?tab=clients" class="refresh-btn" title="Обновить">
                        <i class="bi bi-arrow-repeat"></i>
                    </a>
                </div>

                <div class="search-section">
                    <input type="text" class="search-input" id="clientSearchInput"
                           value="@clientSearch"
                           placeholder="🔍 Поиск по имени или телефону..."
                           oninput="filterClients(this.value)" />
                </div>

                @if (!clients.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">👥</div>
                        <h4>Клиенты не найдены</h4>
                    </div>
                }
                else
                {
                    <div class="stats-summary">
                        <p>
                            <strong>Всего клиентов:</strong> @totalCount |
                            <strong>Отображается:</strong> @clients.Count
                            @if (!string.IsNullOrWhiteSpace(clientSearch))
                            {
                                <span> (поиск: "@clientSearch")</span>
                            }
                        </p>
                    </div>

                    <div class="table-responsive">
                        <table class="admin-table" id="clientsTable">
                            <thead>
                                <tr>
                                    <th class="sortable" onclick="sortClients('name')">Имя <span id="sort-name">↕</span></th>
                                    <th class="sortable" onclick="sortClients('phone')">Телефон <span id="sort-phone">↕</span></th>
                                    <th>Email</th>
                                    <th class="sortable" onclick="sortClients('count')">Записей <span id="sort-count">↕</span></th>
                                    <th class="sortable" onclick="sortClients('date')">Дата регистрации <span id="sort-date">↕</span></th>
                                    <th>Заметки</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var client in clients)
                                {
                                    int apptCount = appointmentCounts.TryGetValue(client.Id, out int cnt) ? cnt : 0;
                                    <tr class="client-row"
                                        data-name="@client.Name.ToLower()"
                                        data-phone="@client.Phone"
                                        data-count="@apptCount"
                                        data-date="@client.CreatedAt.ToString("yyyyMMdd")">
                                        <td><strong>@client.Name</strong></td>
                                        <td>@client.Phone</td>
                                        <td>@(client.Email ?? "—")</td>
                                        <td><span class="count-badge">@apptCount</span></td>
                                        <td>@client.CreatedAt.ToString("dd.MM.yyyy")</td>
                                        <td>@(client.Notes ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        @* ==================== УСЛУГИ ==================== *@
        else if (activeTab == "services")
        {
            var services = ViewBag.Services as List<Service> ?? new List<Service>();

            <div class="management-section">
                <div class="section-header">
                    <h2><i class="bi bi-grid"></i> Управление услугами</h2>
                    <div class="header-actions">
                        <button class="filter-btn" onclick="openServiceModal(0,'','','0','60')">
                            <i class="bi bi-plus-lg"></i> Добавить услугу
                        </button>
                        <a href="/Admin/Index?tab=services" class="refresh-btn" title="Обновить">
                            <i class="bi bi-arrow-repeat"></i>
                        </a>
                    </div>
                </div>

                @if (!services.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">💅</div>
                        <h4>Услуги не найдены</h4>
                        <p>Добавьте первую услугу</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="admin-table" id="servicesTable">
                            <thead>
                                <tr>
                                    <th class="sortable" onclick="sortServices('name')">Название <span id="svc-sort-name">↕</span></th>
                                    <th>Описание</th>
                                    <th class="sortable" onclick="sortServices('price')">Цена <span id="svc-sort-price">↕</span></th>
                                    <th class="sortable" onclick="sortServices('duration')">Длительность <span id="svc-sort-duration">↕</span></th>
                                    <th>Активна</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var svc in services)
                                {
                                    string svcDesc = (svc.Description ?? "").Replace("'", "\\'");
                                    string svcName = svc.Name.Replace("'", "\\'");
                                    string activeColor = svc.IsActive ? "#28a745" : "#dc3545";
                                    string activeText = svc.IsActive ? "✓ Да" : "✗ Нет";
                                    string toggleIcon = svc.IsActive ? "eye-slash" : "eye";

                                    <tr class="svc-row"
                                        data-name="@svc.Name.ToLower()"
                                        data-price="@svc.Price"
                                        data-duration="@svc.DurationMinutes">
                                        <td><strong>@svc.Name</strong></td>
                                        <td>@(svc.Description ?? "—")</td>
                                        <td class="price-cell">@svc.Price.ToString("C")</td>
                                        <td>@svc.DurationMinutes мин</td>
                                        <td><span style="color:@activeColor">@activeText</span></td>
                                        <td class="actions-cell">
                                            <button class="btn-icon edit"
                                                    onclick="openServiceModal(@svc.Id,'@svcName','@svcDesc','@svc.Price','@svc.DurationMinutes')"
                                                    title="Редактировать">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <form method="post" action="/Admin/ToggleService" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="serviceId" value="@svc.Id" />
                                                <button type="submit" class="btn-icon delete" title="@(svc.IsActive ? "Деактивировать" : "Активировать")">
                                                    <i class="bi bi-@toggleIcon"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            @* Модалка услуги *@
            <div class="modal-overlay" id="serviceModal" style="display:none" onclick="if(event.target===this)closeServiceModal()">
                <div class="modal-content">
                    <div class="modal-header">
                        <h3 id="serviceModalTitle"><i class="bi bi-grid"></i> Услуга</h3>
                        <button class="modal-close" onclick="closeServiceModal()">✕</button>
                    </div>
                    <form method="post" action="/Admin/SaveService">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="serviceId" id="serviceId" />
                        <div class="modal-body">
                            <div class="form-group">
                                <label class="form-label">Название</label>
                                <input type="text" class="form-control" name="name" id="serviceName" placeholder="Название услуги" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Описание</label>
                                <textarea class="form-control" name="description" id="serviceDescription" rows="3"></textarea>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Цена (₽)</label>
                                <input type="number" class="form-control" name="price" id="servicePrice" step="0.01" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Длительность (мин)</label>
                                <input type="number" class="form-control" name="duration" id="serviceDuration" />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn-secondary" onclick="closeServiceModal()">Отмена</button>
                            <button type="submit" class="btn-primary">Сохранить</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        @* ==================== РАСПИСАНИЕ ==================== *@
        else if (activeTab == "schedule")
        {
            var blockedSlots = ViewBag.BlockedSlots as List<LashBooking.Domain.Entities.BlockedSlot> ?? new();

            <div class="management-section">
                <div class="section-header">
                    <h2><i class="bi bi-calendar-x"></i> Управление расписанием</h2>
                </div>

                @* Форма блокировки *@
                <div class="schedule-form">
                    <h3 class="schedule-form-title">Заблокировать время</h3>
                    <form method="post" action="/Admin/BlockSlot">
                        @Html.AntiForgeryToken()
                        <div class="schedule-form-row">
                            <div class="form-group">
                                <label class="form-label">Дата</label>
                                <input type="date" class="form-control" name="date"
                                       min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Время</label>
                                <select class="form-control" name="hour">
                                    <option value="-1">Весь день</option>
                                    @for (int h = 9; h < 18; h++)
                                    {
                                        <option value="@h">@h:00</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Причина (необязательно)</label>
                                <input type="text" class="form-control" name="reason" placeholder="Например: выходной" />
                            </div>
                            <div class="form-group form-group-btn">
                                <button type="submit" class="btn-primary">Заблокировать</button>
                            </div>
                        </div>
                    </form>
                </div>

                @* Список заблокированных слотов *@
                <h3 class="schedule-list-title">Заблокированные слоты</h3>

                @if (!blockedSlots.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">📅</div>
                        <h4>Нет заблокированных слотов</h4>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Дата</th>
                                    <th>Время</th>
                                    <th>Причина</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var slot in blockedSlots)
                                {
                                    <tr>
                                        <td><strong>@slot.Date.ToString("dd.MM.yyyy")</strong></td>
                                        <td>
                                            @if (slot.BlockedHour == null)
                                            {
                                                <span class="block-badge day">Весь день</span>
                                            }
                                            else
                                            {
                                                <span class="block-badge hour">@slot.BlockedHour:00</span>
                                            }
                                        </td>
                                        <td>@(slot.Reason ?? "—")</td>
                                        <td>
                                            <form method="post" action="/Admin/UnblockSlot" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="slotId" value="@slot.Id" />
                                                <button type="submit" class="btn-icon delete" title="Снять блокировку">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </div>@* /admin-content *@
</div>@* /admin-container *@


