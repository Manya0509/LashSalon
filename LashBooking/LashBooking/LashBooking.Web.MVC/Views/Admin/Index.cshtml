        }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: #fafafa;
        border-radius: 8px;
        border: 1px dashed #ccc;
    }

    .empty-icon {
        font-size: 3.5rem;
        margin-bottom: 16px;
        opacity: 0.5;
        display: block;
    }

    .empty-state h4 {
        font-size: 1.3rem;
