@using LashBooking.Domain.Entities
@model Review

@{
    string cardClass = Model.IsApproved ? "approved" : "pending";
    string statusClass = Model.IsApproved ? "approved" : "pending";
    string statusText = Model.IsApproved ? "✓ Одобрен" : "⏳ На модерации";
    string clientName = Model.Client?.Name ?? "Неизвестный клиент";
    string clientPhone = Model.Client?.Phone ?? "Нет телефона";
}

<div class="review-card @cardClass">
    <div class="review-header">
        <div class="review-client-info">
            <div class="client-avatar"><i class="bi bi-person-circle"></i></div>
            <div class="client-details">
                <strong>@clientName</strong>
                <span class="client-phone">@clientPhone</span>
            </div>
        </div>
        <div class="review-rating">
            @for (int i = 1; i <= 5; i++)
            {
                <span class="@(i <= Model.Rating ? "star-filled" : "star")">★</span>
            }
        </div>
    </div>

    <div class="review-content">
        <p class="review-text">@Model.Text</p>
        <div class="review-meta">
            <span class="review-date">
                <i class="bi bi-clock"></i>
                @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
            </span>
            <span class="review-status @statusClass">@statusText</span>
        </div>
    </div>

    <div class="review-actions">
        @if (!Model.IsApproved)
        {
            <form method="post" action="/Admin/ApproveReview" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="reviewId" value="@Model.Id" />
                <button type="submit" class="btn-approve">
                    <i class="bi bi-check-circle"></i> Одобрить
                </button>
            </form>
        }
        <form method="post" action="/Admin/RejectReview" style="display:inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reviewId" value="@Model.Id" />
            <button type="submit" class="btn-reject">
                <i class="bi bi-x-circle"></i>
                @(Model.IsApproved ? "Снять с публикации" : "Отклонить")
            </button>
        </form>
        <form method="post" action="/Admin/DeleteReview" style="display:inline">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reviewId" value="@Model.Id" />
            <button type="submit" class="btn-delete"
                    onclick="return confirm('Удалить отзыв?')">
                <i class="bi bi-trash"></i> Удалить
            </button>
        </form>
    </div>
</div>
