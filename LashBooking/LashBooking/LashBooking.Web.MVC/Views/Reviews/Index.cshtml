@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Отзывы — LashLukina";

    var reviews = ViewBag.Reviews as List<LashBooking.Domain.Entities.Review> ?? new();
    double averageRating = ViewBag.AverageRating ?? 0.0;
    bool isAuthenticated = ViewBag.IsAuthenticated ?? false;
    string phone = ViewBag.Phone ?? "";
    string? message = ViewBag.Message as string;
    bool isSuccess = ViewBag.IsSuccess ?? false;
}

<div class="container mt-5">

    <div class="back-button-container">
        <a href="/" class="back-btn">
            <span class="back-icon">←</span> Назад
        </a>
    </div>

    <h2 class="reviews-title">Отзывы клиентов</h2>

<div class="reviews-summary">
    <div class="summary-rating">
        <span class="summary-value">@averageRating.ToString("F1")</span>
        <div class="summary-stars">
            @for (int i = 1; i <= 5; i++)
            {
                <span class="@(i <= (int)Math.Round(averageRating) ? "star-filled" : "star")">★</span>
            }
        </div>
        <span class="summary-count">@reviews.Count @(reviews.Count == 1 ? "отзыв" : reviews.Count < 5 ? "отзыва" : "отзывов")</span>
    </div>
</div>


<div class="row">
    @foreach (var review in reviews)
    {
        <div class="col-md-6 mb-4">
            <div class="card shadow p-3 review-card">
                <h5>@(review.Client?.Name ?? "Анонимный клиент")</h5>
                <div class="stars">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span class="@(i <= review.Rating ? "star-filled" : "star")">★</span>
                    }
                </div>
                <p class="mt-2">@review.Text</p>
                <small class="text-muted">@review.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</small>
            </div>
        </div>
    }
</div>


    @if (!reviews.Any())
    {
        <div class="text-center my-5">
            <p class="text-muted">Пока нет отзывов. Будьте первым!</p>
        </div>
    }

    <hr style="border: none; border-top: 1px solid #eee; margin: 30px 0;" />

<div class="review-form-section">
    <h4>Оставить отзыв</h4>
</div>


    @* Уведомление об успехе или ошибке *@
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert mt-3 @(isSuccess ? "alert-success" : "alert-danger")">
            @message
        </div>
    }

    <div class="row">
        <div class="col-md-6">

            @* POST форма — вместо @onclick="AddReview" в Blazor *@
            <form method="post" action="/Reviews/Add">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Ваш телефон</label>
                    @if (isAuthenticated)
                    {
                        <input class="form-control" name="phone" value="@phone" readonly />
                        <small class="text-success">
                            <i class="bi bi-check-circle"></i> Автоматически заполнено из профиля
                        </small>
                    }
                    else
                    {
                        <input class="form-control" name="phone" placeholder="+7 (999) 123-45-67" value="@phone" />
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">Оценка</label>
                    <select class="form-control" name="rating">
                        <option value="5">5 ⭐</option>
                        <option value="4">4 ⭐</option>
                        <option value="3">3 ⭐</option>
                        <option value="2">2 ⭐</option>
                        <option value="1">1 ⭐</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Ваш отзыв</label>
                    <textarea class="form-control" name="text" rows="4"
                              placeholder="Расскажите о вашем опыте..."></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Отправить отзыв</button>

                @if (!isAuthenticated)
                {
                    <div class="mt-3">
                        <small class="text-muted">
                            Уже есть аккаунт?
                            <a href="/Auth/Login" class="text-primary">Войдите</a>,
                            чтобы телефон заполнился автоматически
                        </small>
                    </div>
                }

            </form>

        </div>
    </div>

</div>

<style>
    .back-button-container {
        margin: 0 0 10px 0;
    }

    .back-btn {
        background: transparent;
        color: #444;
        border: 2px solid #333;
        border-radius: 30px;
        padding: 8px 20px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .back-btn:hover {
            background: #555;
            color: white;
            transform: translateX(-3px);
        }

    .back-icon {
        font-size: 1.2rem;
        line-height: 1;
    }

    /* Заголовок и сводка */
    .reviews-title {
        font-size: 2rem;
        font-weight: 600;
        text-align: center;
        color: #333;
        margin: 20px 0 15px;
    }

    .reviews-summary {
        text-align: center;
        margin-bottom: 30px;
    }

    .summary-rating {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #f8f8f8;
        padding: 12px 24px;
        border-radius: 10px;
        border: 1px solid #eee;
    }

    .summary-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #333;
    }

    .summary-stars {
        display: flex;
        gap: 2px;
    }

    .summary-count {
        font-size: 0.9rem;
        color: #777;
    }

    /* Список отзывов */
    .reviews-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-bottom: 30px;
    }

    .review-card {
        background: white;
        border: 1px solid #eee;
        border-radius: 10px;
        padding: 20px;
        transition: all 0.2s;
        border-left: 4px solid #27ae60;
    }

        .review-card:hover {
            background: #fafafa;
            border-color: #ddd;
            border-left-color: #27ae60;
        }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 15px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .review-client-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .client-avatar {
        width: 48px;
        height: 48px;
        border-radius: 8px;
        background: #e0e0e0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #666;
    }

    .client-details strong {
        font-size: 1.1rem;
        color: #333;
    }

    .review-rating {
        display: flex;
        gap: 3px;
        background: #f5f5f5;
        padding: 6px 12px;
        border-radius: 6px;
    }

    .star {
        color: #ccc;
        font-size: 1.2rem;
    }

    .star-filled {
        color: #f39c12;
        font-size: 1.2rem;
    }

    .review-content {
        margin: 0;
        padding: 16px;
        background: #fafafa;
        border-radius: 8px;
        border: 1px solid #eee;
    }

    .review-text {
        margin: 0;
        color: #444;
        line-height: 1.5;
    }

    .review-meta {
        display: flex;
        align-items: center;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px dashed #ddd;
    }

    .review-date {
        display: flex;
        align-items: center;
        gap: 5px;
        color: #777;
        font-size: 0.85rem;
    }

    /* Форма отзыва */
    .review-form-section {
        margin-top: 10px;
    }

        .review-form-section h4 {
            font-size: 1.3rem;
            font-weight: 500;
            color: #333;
            margin-bottom: 20px;
        }

    .form-control[readonly] {
        background-color: #f0f0f0;
        cursor: default;
        border-color: #d0d0d0;
        color: #333;
    }

    .text-success {
        color: #555;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

        .text-success i {
            margin-right: 4px;
        }

    @@media (max-width: 768px) {
        .review-header {
            flex-direction: column;
        }

        .summary-rating {
            flex-direction: column;
            gap: 6px;
        }

        .summary-value {
            font-size: 1.5rem;
        }
    }
</style>
